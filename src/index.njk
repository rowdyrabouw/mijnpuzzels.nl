---
layout: layouts/page.njk
---

<div class="wrapper">

  <div class="filter" role="group" aria-label="Filter">
    <button class="active" data-filter="all">Alle</button>
    <button data-filter="done">Gelegd</button>
    <button data-filter="not-done">Niet gelegd</button>
  </div>

  <details>
    <summary>Merk</summary>
    <ol>
      <li><a href="/scan">Barcode scannen</a></li>
      {% for brand, puzzles in puzzles.puzzlesAll | groupby("brand") %}
        <li><a href="#{{ brand }}">{{ brand }}</a></li>
      {% endfor %}
    </ol>
  </details>

  {% for brand, puzzles in puzzles.puzzlesAll | groupby("brand") %}
    {% set index = loop.index %}
    <h2 id="{{ brand }}">{{ brand }}</h2>
    <ol>
      {% for puzzle in puzzles | sort(attribute='title') %}
        {% if puzzle.id > 0 %}
          <li data-done="{{ puzzle.done }}">
            <div class="img">
              <img 
              {% if index > 2 %}loading="lazy"{% endif %}
                width="340"
                alt="{{ puzzle.title }}"
                src="/assets/img/{{ puzzle.id  }}.webp"
              >
              {% if puzzle.done == true %}
                <span class="filler"></span>
                {% include "./_includes/svg/checked.njk" %}
              {% endif %}
              <span class="pieces">{{ puzzle.pieces }}</span>
            </div>
            <strong>{{ puzzle.title }}
              {% if puzzle.eid %}<span class="id">({{ puzzle.eid }})</span>{% endif %}
            </strong>
          </li>
        {% endif %}
      {% endfor %}
    </ol>
  {% endfor %}
</div>

<script>
  document.querySelector('.filter').addEventListener('click', (e) => {
    const btn = e.target.closest('button');
    if (!btn) return;
    const filter = btn.dataset.filter;
    document.querySelectorAll('.filter button').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    document.querySelectorAll('li[data-done]').forEach(li => {
      if (filter === 'all') li.hidden = false;
      else if (filter === 'done') li.hidden = li.dataset.done !== 'true';
      else li.hidden = li.dataset.done === 'true';
    });
  });
</script>